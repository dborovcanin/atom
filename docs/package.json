{
  "name": "atom-docs",
  "version": "0.1.0",
  "private": true,
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.10"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build && node scripts/nest-static-export.mjs",
    "start": "serve out",
    "deploy": "pnpm run build && wrangler deploy",
    "upload": "pnpm run build && wrangler versions upload"
  },
  "dependencies": {
    "fumadocs-core": "^14",
    "fumadocs-mdx": "^11",
    "fumadocs-ui": "^14",
    "mermaid": "^11.15.0",
    "next": "^15.5.18",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@types/mdx": "^2.0.13",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10",
    "postcss": "^8",
    "tailwindcss": "^3",
    "typescript": "^5",
    "serve": "^14.2.5",
    "wrangler": "^4.95.0"
  },
  "packageManager": "pnpm@10.33.0"
}
